# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# private QA test emails (copy .qa_test_emails.json.example to .qa_test_emails.json)
.qa_test_emails.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# clerk configuration (can include secrets)
/.clerk/
.vercel_bypass
.clerk_session
spike-clients.json
spike-token-*.json
.playwright_user_data/

# QA test artifacts (screenshots, tokens, agent configs)
qa_proof_*.png
qa-test-agents.json
qa-token-*.json
dashboard.png
.playwright-cli/

# nested node_modules from spike scripts (not managed by root package.json)
docs/skills/*/scripts/node_modules/
scripts/*/node_modules/

# security scan artifacts
*.pdf
*_results.txt
fluidattacks-config.yaml
zap.yaml
semgrep_results.txt

# misc dev artifacts
local_*.txt
local_*.log
vercel_run_logs*.txt
dashboard_fetch.html
verify-ui.ts
test-clerk-token.ts
*.png
